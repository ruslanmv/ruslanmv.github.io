---
# RSS 2.0 + iTunes + Podcasting 2.0 feed for the narrated audio essays.
# Generated by Jekyll. Source of truth:
#   - channel metadata : _data/podcast.yml
#   - episode audio     : _data/audio_manifest.json (the audio pipeline output)
#   - episode metadata  : front matter of each post/page with `audio: true`
# An episode appears here when a document has `audio: true`, a matching manifest
# entry, and is not opted out with `podcast: false`. Audio-bearing *pages*
# (non-posts) must opt IN with `podcast: true` to keep test pages out of the feed.
permalink: /podcast.xml
sitemap: false
layout: null
---
{%- assign pc = site.data.podcast -%}
{%- assign manifest = site.data.audio_manifest -%}
{%- comment -%} Posts are in by default; opted-in audio pages are appended. {%- endcomment -%}
{%- assign audio_posts = site.posts | where: "audio", true -%}
{%- assign audio_pages = site.pages | where: "audio", true | where: "podcast", true -%}
{%- assign episodes = audio_posts | concat: audio_pages | sort: "date" | reverse -%}
{%- assign cover = pc.image | absolute_url -%}
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0"
     xmlns:itunes="http://www.itunes.com/dtds/podcast-1.0.dtd"
     xmlns:content="http://purl.org/rss/1.0/modules/content/"
     xmlns:atom="http://www.w3.org/2005/Atom"
     xmlns:podcast="https://podcastindex.org/namespace/1.0">
  <channel>
    <title>{{ pc.title | escape }}</title>
    <link>{{ pc.link | default: site.url }}</link>
    <atom:link href="{{ pc.feed_url | default: '/podcast.xml' | absolute_url }}" rel="self" type="application/rss+xml"/>
    <language>{{ pc.language | default: 'en-us' }}</language>
    <copyright>{{ pc.copyright | escape }}</copyright>
    <description>{{ pc.description | strip_newlines | strip | escape }}</description>
    {%- if pc.subtitle %}
    <itunes:subtitle>{{ pc.subtitle | escape }}</itunes:subtitle>
    {%- endif %}
    <itunes:summary>{{ pc.description | strip_newlines | strip | escape }}</itunes:summary>
    <itunes:author>{{ pc.author | escape }}</itunes:author>
    <itunes:type>{{ pc.type | default: 'episodic' }}</itunes:type>
    <itunes:explicit>{% if pc.explicit %}true{% else %}false{% endif %}</itunes:explicit>
    <itunes:owner>
      <itunes:name>{{ pc.owner_name | default: pc.author | escape }}</itunes:name>
      <itunes:email>{{ pc.owner_email }}</itunes:email>
    </itunes:owner>
    <itunes:image href="{{ cover }}"/>
    <image>
      <url>{{ cover }}</url>
      <title>{{ pc.title | escape }}</title>
      <link>{{ pc.link | default: site.url }}</link>
    </image>
    <itunes:category text="{{ pc.category | default: 'Technology' | escape }}">
      {%- if pc.subcategory and pc.subcategory != '' %}
      <itunes:category text="{{ pc.subcategory | escape }}"/>
      {%- endif %}
    </itunes:category>
    {%- if pc.guid and pc.guid != '' %}
    <podcast:guid>{{ pc.guid }}</podcast:guid>
    {%- endif %}
    <generator>Jekyll podcast.xml</generator>
    <lastBuildDate>{{ site.time | date_to_rfc822 }}</lastBuildDate>
    {%- for ep in episodes %}
    {%- if ep.podcast == false %}{% continue %}{% endif %}
    {%- assign audio_key = ep.audio_slug | default: ep.slug -%}
    {%- assign audio = manifest[audio_key] -%}
    {%- if audio == nil or audio.audio_url == nil %}{% continue %}{% endif %}
    {%- comment -%} pubDate: post date, else the manifest's updated_at. {%- endcomment -%}
    {%- assign pub = ep.date | default: audio.updated_at -%}
    {%- comment -%} Enclosure length: real bytes if the manifest has them, else
        estimate from duration (m:ss) at the pipeline's 192 kbps (~24000 B/s). {%- endcomment -%}
    {%- assign est_bytes = 0 -%}
    {%- assign dparts = audio.duration | split: ':' -%}
    {%- if dparts.size == 2 -%}
      {%- assign secs = dparts[0] | times: 60 | plus: dparts[1] -%}
      {%- assign est_bytes = secs | times: 24000 -%}
    {%- elsif dparts.size == 3 -%}
      {%- assign secs = dparts[0] | times: 3600 | plus: dparts[1] | times: 60 | plus: dparts[2] -%}
      {%- assign est_bytes = secs | times: 24000 -%}
    {%- endif -%}
    {%- assign enclosure_len = audio.bytes | default: est_bytes -%}
    {%- assign ep_title = ep.headline | default: ep.title -%}
    {%- assign ep_summary = ep.card_excerpt | default: ep.excerpt | strip_html | strip_newlines | strip -%}
    {%- assign ep_image = ep.card_image | default: ep.image | default: ep.header.image -%}
    <item>
      <title>{{ ep_title | strip_html | escape }}</title>
      <link>{{ ep.url | absolute_url }}</link>
      <guid isPermaLink="true">{{ ep.url | absolute_url }}</guid>
      <pubDate>{{ pub | date_to_rfc822 }}</pubDate>
      <description><![CDATA[{{ ep_summary }}]]></description>
      <itunes:summary>{{ ep_summary | escape }}</itunes:summary>
      <itunes:author>{{ ep.author_name | default: pc.author | escape }}</itunes:author>
      <enclosure url="{{ audio.audio_url }}" length="{{ enclosure_len }}" type="audio/mpeg"/>
      {%- if audio.duration and audio.duration != '' %}
      <itunes:duration>{{ audio.duration }}</itunes:duration>
      {%- endif %}
      <itunes:episodeType>full</itunes:episodeType>
      <itunes:explicit>{% if ep.explicit %}true{% else %}false{% endif %}</itunes:explicit>
      {%- if ep_image %}
      <itunes:image href="{{ ep_image | absolute_url }}"/>
      {%- endif %}
    </item>
    {%- endfor %}
  </channel>
</rss>
