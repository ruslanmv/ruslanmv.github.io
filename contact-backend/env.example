# Example environment for the contact Worker.
# Real secrets are set with `wrangler secret put ...`, NOT committed and NOT in GitHub.

# Resend API key — set as a Worker SECRET (wrangler secret put RESEND_API_KEY).
# Get it from https://resend.com → API Keys. Starts with "re_".
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where contact messages are delivered (your inbox).
CONTACT_TO_EMAIL=contact@ruslanmv.com

# Verified sender. ruslanmv.com is verified in Resend, so this works.
CONTACT_FROM_EMAIL=Ruslan Magana Vsevolodovna <contact@ruslanmv.com>
