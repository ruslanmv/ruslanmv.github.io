# Local audio pipeline configuration for `make audio` / `make serve`.
#
# Copy to `.env` and fill in. `.env` is git-ignored — never commit secrets.
#   cp .env.example .env
#
# These let `make serve` upload generated MP3s to Cloudflare R2 so local
# playback streams from R2 exactly like production. Without them, audio is
# still generated locally; the upload step is simply skipped.

R2_ACCOUNT_ID=d25a9fb6761ec9c7c7f25529f93f5acb
R2_BUCKET=blog-audio
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_PUBLIC_BASE_URL=https://pub-18ecc6bab6074b2e89efa5c36d39a544.r2.dev

# Optional overrides:
# KOKORO_VOICE=af_heart
# KOKORO_SPEED=0.96
# AUDIO=0            # skip audio entirely on `make serve`
